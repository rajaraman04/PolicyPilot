# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# Quick start: you can ingest and embed with NO API key (embeddings default to a
# local sentence-transformers model). You only need an LLM key to generate answers.

# --- Answer-generation LLM ---
# Which provider generates the final answer. Options: openai (default) | anthropic
LLM_PROVIDER=openai

# OpenAI (needed if LLM_PROVIDER=openai, or if EMBED_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini

# Anthropic (needed only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_LLM_MODEL=claude-sonnet-5

# --- Embeddings ---
# local  = sentence-transformers, runs on your machine, no API key required (default)
# openai = OpenAI embeddings API (reuses OPENAI_API_KEY)
EMBED_PROVIDER=local
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval ---
TOP_K=5

# --- Reproducibility (eval) ---
# Seed for providers that support it (OpenAI; Anthropic has none). Best-effort:
# the runner records system_fingerprint so provider-side changes stay visible.
LLM_SEED=20240720

# --- Pricing overrides (USD per 1M tokens) ---
# Only needed if the built-in table in app/pricing.py has gone stale.
# PRICE_INPUT_PER_1M=0.15
# PRICE_OUTPUT_PER_1M=0.60

# --- Storage / paths ---
CHROMA_DIR=chroma_store
CHROMA_COLLECTION=policypilot
SQLITE_PATH=policypilot.db
DATA_DIR=data
