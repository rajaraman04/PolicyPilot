# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM / embeddings provider ---
# Options: openai (default) | anthropic
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (used when LLM_PROVIDER=anthropic)
# Note: embeddings still come from OPENAI_EMBED_MODEL — Anthropic has no embeddings API.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_LLM_MODEL=claude-sonnet-5

# --- Storage / paths ---
CHROMA_DIR=chroma_store
CHROMA_COLLECTION=policypilot
SQLITE_PATH=policypilot.db
DATA_DIR=data

# --- Retrieval ---
TOP_K=5
